    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-import": "^2.32.0",
