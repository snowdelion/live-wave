# .env.local
PORT=your_port
FRONTEND_URL=your_frontend_url
NODE_ENV=development

# postgres settings
POSTGRES_USER=your_local_postgres_user
POSTGRES_PASSWORD=your_local_postgres_password
POSTGRES_DB=your_local_postgres_name
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_db_name?schema=public

# redis
REDIS_URL=redis://127.0.0.1:6379
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# secrets
JWT_SECRET=your_secret_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_key
