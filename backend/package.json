{
  "name": "@live-wave/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "dev:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "build": "cross-env NODE_ENV=production prisma generate && pnpm run validate && nest build",
    "start": "cross-env NODE_ENV=production node dist/main",
    "generate": "dotenv -e .env.local -- prisma generate --schema=./prisma/schema",
    "migrate": "dotenv -e .env.local -- prisma migrate dev --schema=./prisma/schema",
    "studio": "prisma studio",
    "format": "prettier --write .",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier .",
    "lint": "eslint .",
    "validate": "pnpm run typecheck && pnpm run format && pnpm run lint:fix",
    "test": "cross-env NODE_ENV=test vitest",
    "test:run": "cross-env NODE_ENV=test vitest --watch",
    "test:cov": "cross-env NODE_ENV=test vitest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.10",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.10",
    "@nestjs/platform-express": "^11.0.10",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/client": "^6.0.0",
    "@types/ms": "^2.1.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "ms": "^2.1.3",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
