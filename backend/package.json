{
  "name": "@live-wave/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development nest start --watch",
    "dev:debug": "NODE_ENV=development nest start --debug --watch",
    "build": "NODE_ENV=production npm run validate && nest build && prisma generate",
    "start": "NODE_ENV=production node dist/main",
    "generate": "dotenv -e .env.local -- prisma generate --schema=./prisma/schema",
    "migrate": "dotenv -e .env.local -- prisma migrate dev --schema=./prisma/schema",
    "studio": "prisma studio",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "validate": "npm run typecheck && npm run format:check && npm run lint",
    "test": "NODE_ENV=test vitest",
    "test:run": "NODE_ENV=test vitest --watch",
    "test:cov": "NODE_ENV=test vitest --coverage"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.0",
    "@nestjs/common": "^11.0.10",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.10",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.10",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^2.1.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "vitest": "^2.1.3"
  }
}
