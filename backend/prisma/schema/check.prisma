model Check {
  id String @id @default(cuid())

  status       StatusEnum
  statusCode   Int?
  responseTime Int?
  error        String?

  monitorId String
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  checkedAt DateTime @default(now())

  @@index([monitorId])
  @@index([checkedAt])
  @@index([status])
}
