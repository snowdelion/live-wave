model Monitor {
  id String @id @default(cuid())

  name          String
  url           String
  method        Method      @default(HEAD)
  checkInterval Int         @default(10) // minutes
  timeout       Int         @default(5000) // milliseconds
  lastStatus    StatusEnum?

  clientId String
  checks   Check[]

  lastCheckedAt DateTime?
  nextCheckAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

enum Method {
  HEAD
  GET
}
