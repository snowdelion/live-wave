enum MonitorType {
  HTTP
  ICMP
  TCP
  DNS
}

model Monitor {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  type          MonitorType @default(HTTP)
  checkInterval Int         @default(10) // minutes
  timeout       Int         @default(5000) // milliseconds
  lastStatus    StatusEnum?

  checks Check[]

  httpMonitor HttpMonitor?
  icmpMonitor IcmpMonitor?
  tcpMonitor  TcpMonitor?
  dnsMonitor  DnsMonitor?

  lastCheckedAt DateTime?
  nextCheckAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([type])
}

model HttpMonitor {
  monitorId String  @id
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  url    String
  method Method @default(HEAD)
}

enum Method {
  HEAD
}

model IcmpMonitor {
  monitorId String  @id
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  host String
}

model TcpMonitor {
  monitorId String  @id
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  host String
  port Int
}

model DnsMonitor {
  monitorId String  @id
  monitor   Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  host       String
  recordType RecordType
}

enum RecordType {
  A
  AAAA
  MX
  TXT
  CNAME
}
